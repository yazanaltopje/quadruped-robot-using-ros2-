<launch>
    <!-- Load URDF -->
    <let name="urdf_path" 
         value="$(find-pkg-share qu_description)/urdf/my_robot.urdf.xacro" />

    <!-- Robot State Publisher -->
    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" 
               value="$(command 'xacro $(var urdf_path)')" />
        <param name="use_sim_time" value="false"/>
        <param name="publish_frequency" value="50.0"/>
    </node>

    
    <node pkg="controller_manager" exec="ros2_control_node" output="screen">
        <param name="robot_description" 
               value="$(command 'xacro $(var urdf_path)')" />
        <param from="$(find-pkg-share qu_bringup)/config/my_robot_controllers.yaml" />
        
        <remap from="/controller_manager/robot_description" to="/robot_description" />
    </node>

    <!-- Spawn Controllers -->
    <node pkg="controller_manager" exec="spawner" args="joint_state_broadcaster" />
    <node pkg="controller_manager" exec="spawner" args="position_controller" />

    <!-- RViz2 -->
    <let name="rviz_config_path" 
         value="$(find-pkg-share qu_description)/rviz/urdf_config.rviz" />
    <node pkg="rviz2" exec="rviz2" output="screen" 
          args="-d $(var rviz_config_path)" /> 
</launch>